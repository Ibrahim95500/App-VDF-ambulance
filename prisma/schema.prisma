generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  roles         Role[]           @default([SALARIE])
  password      String?
  birthDate     DateTime?
  firstName     String?
  lastName      String?
  phone         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  accounts      Account[]
  requests      AdvanceRequest[]
  leaveRequests  LeaveRequest[]
  serviceRequests ServiceRequest[]
  appointmentRequests AppointmentRequest[]
  notifications  Notification[]
  sessions       Session[]

  isActive       Boolean   @default(true)
  deletionReason String?   @db.Text
  pushSubscriptions PushSubscription[]
  fcmTokens      FcmToken[]
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  regulationAssignments RegulationAssignment[]
  disponibilities       Disponibility[]

  // Champs Régulation
  structure      Structure?
  diploma        Diploma?
  shift          Shift?
  preference     Preference?
  isTeamLeader   Boolean   @default(false)
  isRegulateur   Boolean   @default(false)
  oubliCount     Int       @default(0)

  // Relations Régulation
  leaderAssignments   PlanningAssignment[] @relation("Leader")
  teammateAssignments PlanningAssignment[] @relation("Teammate")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([endpoint])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  status    String?
  link      String?
  read      Boolean  @default(false)
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AdvanceRequest {
  id          String        @id @default(cuid())
  amount      Float
  reason      String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  targetMonth String
  adminComment String?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id         String        @id @default(cuid())
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  startAmPm  String
  endAmPm    String
  reason     String?
  attachment String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  adminComment String?
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceRequest {
  id          String        @id @default(cuid())
  source      RequestSource @default(APP)
  category    String?       // e.g. RH, Matériel, Autre
  subject     String
  description String        @db.Text
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  adminComment String?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  SALARIE
  RH
  REGULATEUR
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestSource {
  APP
  WHATSAPP
  EMAIL
}

enum LeaveType {
  CP
  MA
  CSS
}

enum Structure {
  MARK
  VDF
  LES_2
}

enum Diploma {
  AUXILIAIRE
  DEA
}

enum Shift {
  JOUR
  NUIT
  VACATAIRE
  JOUR_NUIT
}

enum Preference {
  NORMAL
  SAMEDI
  NUIT
  MATIN
}

enum AssignmentStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum AppointmentType {
  RENDEZ_VOUS
  CONVOCATION
  AUGMENTATION_SALAIRE @map("Augmentation / Salaire")
  CONFLIT_MEDIATION     @map("Conflit / Médiation")
  AVERTISSEMENT_SANCTION @map("Avertissement ou Sanction")
  INCIDENT_TRANSPORT    @map("Incident de transport")
  POINT_CARRIERE        @map("Point carrière")
  SOLDE_DE_TOUT_COMPTE @map("Solde de tout compte")
  EVALUATION_ANNUELLE   @map("Évaluation annuelle")
  AUTRE_METIER          @map("Autre métier")
  MODIFICATION_CONTRAT  @map("Modification du contrat")
}

enum RescheduleStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model AppointmentRequest {
  id              String           @id @default(cuid())
  userId          String
  type            AppointmentType  @default(RENDEZ_VOUS)
  initiator       Role             @default(SALARIE)
  reason          String
  description     String?          @db.Text
  status          RequestStatus    @default(PENDING)
  appointmentDate DateTime?
  appointmentMode String?          // e.g., "BUREAU", "TELEPHONE"
  adminComment    String?
  rescheduleStatus RescheduleStatus?
  rescheduleHistory Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id                 String               @id @default(cuid())
  plateNumber        String               @unique
  category           Structure
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  assignments        PlanningAssignment[]
}

model PlanningAssignment {
  id                 String           @id @default(cuid())
  date               DateTime
  vehicleId          String
  leaderId           String
  teammateId         String
  status             AssignmentStatus @default(PENDING)
  leaderValidated    Boolean          @default(false)
  leaderValidatedAt  DateTime?
  teammateValidated  Boolean          @default(false)
  teammateValidatedAt DateTime?
  startTime          String?
  endTime            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])
  leader      User             @relation("Leader", fields: [leaderId], references: [id])
  teammate    User             @relation("Teammate", fields: [teammateId], references: [id])
}

model CronJob {
  id        String   @id @default(cuid())
  type      String   // SEND_PLANNING, CHECK_VALIDATION
  date      String   // Format yyyy-MM-dd
  status    String   @default("SUCCESS")
  createdAt DateTime @default(now())

  @@unique([type, date])
}

enum RegulationType {
  MATIN
  SOIR
  DIALYSE
}

enum DisponibilityStatus {
  AVAILABLE
  INTEGRATED
}

model RegulationAssignment {
  id          String         @id @default(cuid())
  userId      String
  date        DateTime
  type        RegulationType
  startTime   String
  validated   Boolean        @default(false)
  validatedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Disponibility {
  id          String              @id @default(cuid())
  userId      String
  date        DateTime
  startTime   String
  validated   Boolean             @default(false)
  validatedAt DateTime?
  status      DisponibilityStatus @default(AVAILABLE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}
